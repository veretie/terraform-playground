aws_region   = "eu-west-2"
project_name = "terraform-playground"
environment  = "dev"

tags = {
  Project     = "terraform-playground"
  Environment = "dev"
  ManagedBy   = "terraform"
}

s3_buckets = {
  inbound = {
    # bucket_name can be set when the generated name is already taken globally.
    versioning_enabled = true
  }
}

sqs_queues = {
  jobs = {
    visibility_timeout_seconds = 60
    create_dlq                 = true
    max_receive_count          = 5
  }
}

ses_identities = {
  main = {
    domain       = "example.com"
    mail_from    = "mail.example.com"
    dkim_enabled = true
  }
}
